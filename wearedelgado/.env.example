# Server-only: usadas por las Server Actions y los Server Components
# (lib/supabase/server.ts, lib/supabase/server-session.ts).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=xxxx

# Expuestas al navegador a propósito: el backoffice las usa para subir
# archivos grandes (PDFs de catálogo, fotos de proyecto) directamente a
# Supabase Storage desde el cliente (lib/supabase/browser.ts), evitando el
# límite de tamaño de las Server Actions en hostings serverless. Mismos
# valores que las de arriba; la anon key no es secreta (protegida por RLS).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
